# Aether Grimoire Environment Variables
# Copier ce fichier en .env.local et remplir les valeurs nécessaires

# API Configuration (si besoin)
# VITE_API_URL=https://api.example.com

# Game Configuration
# VITE_GAME_MODE=production

# Analytics (optionnel)
# VITE_ANALYTICS_ID=

# Feature flags
# VITE_ENABLE_DEBUG=false
